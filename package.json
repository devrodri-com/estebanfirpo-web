{
  "name": "estebanfirpo-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "catalog:slugs": "node scripts/generate-project-slugs.mjs",
    "phase3b:matrix": "node --conditions=react-server --import tsx scripts/generate-phase-3b-project-migration-matrix.mjs",
    "phase3b:matrix:check": "node --conditions=react-server --import tsx scripts/generate-phase-3b-project-migration-matrix.mjs --check",
    "phase3b:models:check": "node --conditions=react-server --import tsx scripts/check-canonical-project-view-models.ts",
    "phase3b:check": "npm run phase3b:matrix:check && npm run phase3b:models:check",
    "predev": "npm run catalog:slugs",
    "dev": "next dev --turbopack",
    "prebuild": "npm run catalog:slugs",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.12",
    "libphonenumber-js": "^1.12.33",
    "lucide-react": "^0.542.0",
    "next": "15.5.20",
    "next-intl": "^4.13.2",
    "postcss": "8.5.14",
    "react": "19.1.8",
    "react-dom": "19.1.8",
    "react-hook-form": "^7.62.0",
    "react-phone-number-input": "^3.4.14",
    "resend": "^6.17.2",
    "server-only": "0.0.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.20",
    "tailwindcss": "^4.3.0",
    "tsx": "4.23.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "8.5.14"
  }
